{
  "$id": "shared/name-block",
  "description": "Standard name block — first, middle (optional), last name",
  "type": "fieldset",
  "legend": "Your name",
  "fields": [
    {
      "id": "last-name",
      "type": "text",
      "label": "Last name",
      "required": true,
      "validation": {
        "maxLength": 100
      }
    },
    {
      "id": "first-name",
      "type": "text",
      "label": "First name",
      "required": true,
      "validation": {
        "maxLength": 100
      }
    },
    {
      "id": "middle-name",
      "type": "text",
      "label": "Middle name(s)",
      "required": false,
      "hint": "Leave blank if you do not have a middle name",
      "validation": {
        "maxLength": 100
      }
    }
  ]
}
